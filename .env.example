# ─────────────────────────────────────────────────────────
# Copy file này thành .env và điền giá trị thực tế.
# .env KHÔNG được commit lên git.
# ─────────────────────────────────────────────────────────

# ── Spring Boot ──────────────────────────────────────────
SERVER_PORT=8080

# ── Database (dùng khi chạy profile db) ─────────────────
# Khi chạy với Docker: DB_URL dùng localhost, port theo POSTGRES_PORT
DB_URL=jdbc:postgresql://localhost:5432/loan_onboarding
DB_USERNAME=postgres
DB_PASSWORD=123456

# ── PostgreSQL Docker service ────────────────────────────
# Port PostgreSQL expose ra máy host (đổi nếu bị xung đột với local PG)
POSTGRES_PORT=5432

# ── FPT AI OCR ───────────────────────────────────────────
# PRODUCTION: thay bằng API key thật, không commit key lên git
FPTAI_API_KEY=lqC33wLZQ9ILpTjRuV32W3zTWSDSOFtd

